<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:state_enabled="false"
        android:state_checked="false"
        android:color="@color/zz_switch_thumb_off_disabled"
        android:alpha="0.12"/>
    <item
        android:state_enabled="false"
        android:state_checked="true"
        android:color="@color/switch_thumb_on_disabled"/>
    <item
        android:state_checked="true"
        android:color="@color/zz_switch_bar_background_on"/>
    <item
        android:state_checked="false"
        android:color="@color/zz_switch_track_stroke_color_off"/>
</selector>
