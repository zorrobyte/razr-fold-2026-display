<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="?android:attr/listPreferredItemHeightSmall"
    android:paddingStart="?android:attr/listPreferredItemPaddingStart"
    android:paddingEnd="?android:attr/listPreferredItemPaddingEnd">
    <include layout="@layout/settingslib_icon_frame"/>
    <RelativeLayout
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textAppearance="?android:attr/textAppearanceListItem"
            android:ellipsize="marquee"
            android:id="@android:id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"
            android:hyphenationFrequency="normalFast"
            android:lineBreakWordStyle="phrase"/>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layout_bt_codec_summary"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:layout_below="@android:id/title"
            android:layout_alignStart="@android:id/title">
            <TextView
                android:textAppearance="?android:attr/textAppearanceListItem"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:id="@+id/tv_bt_codec_hfp"
                android:background="@drawable/ic_bt_bg_round"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="2.5dp"
                android:drawableStart="@drawable/ic_bt_hfp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceListItem"
                android:textSize="11sp"
                android:textStyle="bold"
                android:gravity="center_vertical"
                android:id="@+id/tv_bt_codec_a2dp"
                android:background="@drawable/ic_bt_bg_round"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:drawablePadding="2.5dp"
                android:drawableStart="@drawable/ic_bt_a2dp"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:layout_marginStart="4dp"/>
        </LinearLayout>
        <TextView
            android:textAppearance="?android:attr/textAppearanceListItemSecondary"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@android:id/summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="10"
            android:layout_below="@+id/layout_bt_codec_summary"
            android:layout_alignStart="@+id/layout_bt_codec_summary"
            android:hyphenationFrequency="normalFast"
            android:lineBreakWordStyle="phrase"/>
    </RelativeLayout>
    <include layout="@layout/preference_two_target_divider"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@android:id/widget_frame"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:minWidth="@dimen/two_target_min_width"/>
</LinearLayout>
