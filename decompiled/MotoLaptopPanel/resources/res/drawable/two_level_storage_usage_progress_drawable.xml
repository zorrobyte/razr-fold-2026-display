<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:id="@android:id/background">
        <shape>
            <solid android:color="@color/primary_progress_background_color"/>
        </shape>
    </item>
    <item android:id="@android:id/secondaryProgress">
        <scale
            android:scaleWidth="100%"
            android:useIntrinsicSizeAsMinimum="true">
            <shape>
                <corners
                    android:topRightRadius="@dimen/two_level_progress_drawable_corner"
                    android:bottomRightRadius="@dimen/two_level_progress_drawable_corner"/>
                <solid android:color="?android:attr/textColorPrimary"/>
                <size android:width="8dp"/>
            </shape>
        </scale>
    </item>
    <item android:id="@android:id/progress">
        <scale
            android:scaleWidth="100%"
            android:useIntrinsicSizeAsMinimum="true">
            <shape>
                <corners
                    android:topRightRadius="@dimen/two_level_progress_drawable_corner"
                    android:bottomRightRadius="@dimen/two_level_progress_drawable_corner"/>
                <solid android:color="@color/primary_progress_color"/>
                <size android:width="8dp"/>
            </shape>
        </scale>
    </item>
</layer-list>
