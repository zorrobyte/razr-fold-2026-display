<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@drawable/glass_status_toast_bg"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@drawable/glass_status_toast_type_circle_bg"
        android:layout_width="34dp"
        android:layout_height="34dp"
        android:layout_marginHorizontal="12dp">
        <ImageView
            android:id="@+id/typeIcon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_glasses_volume"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/glass_status_toast_text_color"
            android:ellipsize="end"
            android:id="@+id/typeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="2"/>
        <ProgressBar
            android:id="@+id/progress"
            android:layout_width="match_parent"
            android:layout_marginTop="4dp"
            android:max="10"
            android:progress="4"
            android:min="1"
            style="@style/GlassProgressBar"/>
    </LinearLayout>
    <ImageView
        android:layout_width="24dp"
        android:layout_height="12dp"
        android:src="@drawable/ic_glasses_3d"
        android:layout_marginStart="36dp"
        android:layout_marginEnd="22dp"/>
</LinearLayout>
