<?xml version="1.0" encoding="utf-8"?>
<com.motorola.taskbar.recent.TaskSyncreticItemView xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:clipChildren="false"
    android:layout_width="@dimen/taskbar_appitem_width"
    android:layout_height="match_parent">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <View
            android:id="@+id/hover_top_tag"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <ImageView
            android:id="@+id/task_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerInParent="true"/>
        <View
            android:id="@+id/running_tag"
            android:background="@drawable/task_running_bg"
            android:visibility="gone"
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"/>
    </RelativeLayout>
</com.motorola.taskbar.recent.TaskSyncreticItemView>
