<?xml version="1.0" encoding="utf-8"?>
<com.motorola.taskbar.panel.MorePanelLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:theme="@style/TaskBarTheme"
    android:background="@drawable/more_panel_background"
    android:layout_width="@dimen/more_panel_width"
    android:layout_height="wrap_content"
    android:elevation="@dimen/taskbar_popwindow_elevation"
    android:paddingVertical="@dimen/more_panel_vertical_padding">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>
</com.motorola.taskbar.panel.MorePanelLayout>
