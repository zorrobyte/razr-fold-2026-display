<?xml version="1.0" encoding="utf-8"?>
<com.motorola.taskbar.bar.more.MoreItemLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:background="@color/more_item_selector"
    android:layout_width="match_parent"
    android:layout_height="@dimen/more_panel_item_height">
    <FrameLayout
        android:gravity="center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/more_panel_item_icon_horizontal_padding">
        <com.motorola.taskbar.bar.more.MorePanelImageView
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:id="@+id/image"
            android:clickable="false"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="center"
            android:paddingHorizontal="12dp"/>
        <FrameLayout
            android:gravity="center_vertical"
            android:id="@+id/provider_drawable"
            android:layout_width="48dp"
            android:layout_height="48dp"/>
    </FrameLayout>
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/more_panel_item_text_size"
            android:textColor="@color/taskbar_text_color"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <FrameLayout
            android:gravity="center_vertical"
            android:id="@+id/provider_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </FrameLayout>
</com.motorola.taskbar.bar.more.MoreItemLayout>
