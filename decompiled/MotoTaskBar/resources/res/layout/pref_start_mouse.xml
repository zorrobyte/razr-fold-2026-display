<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="vertical"
    android:background="@drawable/bg_top_corner_setting"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:minHeight="?android:attr/listPreferredItemHeightSmall"
    android:layout_marginEnd="36dp">
    <RelativeLayout
        android:paddingLeft="24dp"
        android:layout_width="wrap_content"
        android:layout_height="48dp">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/preference_text_color"
            android:ellipsize="marquee"
            android:id="@android:id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif"
            android:layout_alignParentStart="true"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/preference_summary_color"
            android:gravity="start"
            android:id="@android:id/summary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="10"
            android:layout_below="@android:id/title"
            android:layout_centerVertical="true"
            android:fontFamily="sans-serif"
            android:layout_alignStart="@android:id/title"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/dongle_summary_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_mouse_slow"/>
        <SeekBar
            android:id="@+id/seekbar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:max="100"
            android:progress="10"
            android:layout_weight="1"/>
        <TextView
            android:textSize="16sp"
            android:textColor="@color/dongle_summary_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_mouse_fast"/>
    </LinearLayout>
</LinearLayout>
