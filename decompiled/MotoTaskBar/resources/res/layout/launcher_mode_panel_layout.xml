<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_container"
    android:background="@drawable/launcher_mode_panel_background"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="26dp">
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <TextView
                    android:textSize="20sp"
                    android:textColor="@color/launcher_moder_title_color"
                    android:gravity="start"
                    android:id="@+id/panel_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/launcher_mode_title"
                    android:fontFamily="roboto-medium"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/launcher_moder_summary_color"
                    android:gravity="start"
                    android:id="@+id/panel_summary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/launcher_mode_summary"
                    android:fontFamily="roboto-regular"/>
            </LinearLayout>
            <ImageView
                android:layout_width="83dp"
                android:layout_height="83dp"
                android:src="@drawable/ic_media_center_illustration"
                android:layout_marginStart="27dp"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:paddingTop="5dp"
            android:paddingBottom="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/launcher_moder_label_color"
                android:id="@+id/no_now"
                android:background="@drawable/ripple_percent_10_drawable"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_now"
                android:fontFamily="roboto-medium"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/launcher_moder_label_color"
                android:id="@+id/media_center"
                android:background="@drawable/ripple_percent_10_drawable"
                android:paddingTop="10dp"
                android:paddingBottom="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/launcher_mode_media"
                android:fontFamily="roboto-medium"
                android:paddingStart="15dp"
                android:paddingEnd="15dp"
                android:layout_marginStart="12dp"/>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
