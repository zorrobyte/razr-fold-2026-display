				};

				pmk8550_sdam_43: sdam@9a00 {
					compatible = "qcom,spmi-sdam";
					reg = <0x9a00>;
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x5d>;

					ibb_spur_sqm_timer: sqm-timer@b8 {
						reg = <0xb8 0x02>;
						phandle = <0x1e>;
					};
