				pmk8550_sdam_71: sdam@b600 {
					compatible = "qcom,spmi-sdam";
					reg = <0xb600>;
					phandle = <0x5e>;

					usb_mode: usb-mode@50 {
						reg = <0x50 0x01>;
						phandle = <0x33>;
					};
				};

				pon_hlos@1300 {
					compatible = "qcom,pm8998-pon";
					reg = <0x1300 0x800>;
					reg-names = "pon_hlos", "pon_pbs";

					pwrkey {
						compatible = "qcom,pmk8350-pwrkey";
						interrupts = <0x00 0x13 0x07 0x03>;
						linux,code = <0x74>;
					};

					resin {
						compatible = "qcom,pmk8350-resin";
						interrupts = <0x00 0x13 0x06 0x03>;
						linux,code = <0x72>;
					};
				};

				pmk8550_gpios: pinctrl@b800 {
					compatible = "qcom,pmk8550-gpio";
					reg = <0xb800>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					pinctrl-0 = <&alt_sleep_clk_default>;
					pinctrl-names = "default";
					phandle = <0x5f>;

					alt_sleep_clk {

						alt_sleep_clk_default: alt_sleep_clk_default {
							pins = "gpio1";
							function = "func1";
							input-disable;
							output-enable;
							bias-disable;
							power-source = <0x00>;
							phandle = <0x01>;
						};
					};

					stylus_clk_ctrl {

						stylus_clk_active: stylus_clk_active {
							pins = "gpio5";
							function = "func2";
							bias-disable;
							output-enable;
							input-disable;
							power-source = <0x00>;
							phandle = <0x4c>;
						};

						stylus_clk_suspend: stylus_clk_suspend {
							pins = "gpio5";
							function = "func2";
							bias-high-impedance;
							output-enable;
							input-disable;
							power-source = <0x00>;
							phandle = <0x4d>;
						};
					};

					stylus_fold_clk_ctrl {

						stylus_fold_clk_active: stylus_fold_clk_active {
							pins = "gpio3";
							function = "func2";
							bias-disable;
							output-enable;
							input-disable;
							power-source = <0x00>;
							phandle = <0x50>;
						};

						stylus_fold_clk_suspend: stylus_fold_clk_suspend {
							pins = "gpio3";
							function = "func2";
							bias-high-impedance;
							output-enable;
							input-disable;
							power-source = <0x00>;
							phandle = <0x51>;
						};
					};
				};

				pmk8550_rtc: rtc@6100 {
					compatible = "qcom,pmk8350-rtc";
					reg = <0x6100 0x6200>;
					reg-names = "rtc", "alarm";
					interrupts = <0x00 0x62 0x01 0x01>;
					phandle = <0x60>;
				};

				pmk8550-pwm {
					compatible = "qcom,pmk8550-pwm";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					#pwm-cells = <0x02>;
				};

				pmk8550_vadc: vadc@9000 {
					compatible = "qcom,spmi-adc5-gen3";
					reg = <0x9000 0x9100>;
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					interrupt-names = "adc-sdam0", "adc-sdam1";
					interrupts = <0x00 0x90 0x01 0x01 0x00 0x91 0x01 0x01>;
					#thermal-sensor-cells = <0x01>;
					#io-channel-cells = <0x01>;
					io-channel-ranges;
					pinctrl-0 = <&sys_therm_5_gpio3_default>, <&sys_therm_12_gpio2_default>, <&sys_therm_7_gpio12_default>;
					pinctrl-names = "default";
					phandle = <0x05>;

					pmk8550_offset_ref {
						reg = <0x00>;
						label = "pmk8550_offset_ref";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8550_vref_1p25 {
						reg = <0x01>;
						label = "pmk8550_vref_1p25";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8550_die_temp {
						reg = <0x03>;
						label = "pmk8550_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pm8550_offset_ref {
						reg = <0x100>;
