						label = "pm8550ve_g_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pm8550ve_i_die_temp {
						reg = <0x803>;
						label = "pm8550ve_i_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pmk8550_sys_therm_0 {
						reg = <0x44>;
						label = "pmk8550_sys_therm_0";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pm8550_sys_therm_2 {
						reg = <0x147>;
						label = "pm8550_sys_therm_2";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pm8550_sys_therm_3 {
						reg = <0x144>;
						label = "pm8550_sys_therm_3";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pm8550_sys_therm_5 {
						reg = <0x14a>;
						label = "pm8550_sys_therm_5";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pm8550_sys_therm_6 {
						reg = <0x145>;
						label = "pm8550_sys_therm_6";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pmih010x_sys_therm_7 {
						reg = <0x74d>;
						label = "pmih010x_sys_therm_7";
						qcom,ratiometric;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_sys_therm_8 {
						reg = <0x747>;
						label = "pmih010x_sys_therm_8";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_offset_ref {
						reg = <0x700>;
						label = "pmih010x_offset_ref";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_vref_1p25 {
						reg = <0x701>;
						label = "pmih010x_vref_1p25";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_die_temp {
						reg = <0x703>;
						label = "pmih010x_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_vph_pwr {
						reg = <0x78e>;
						label = "pmih010x_vph_pwr";
						qcom,pre-scaling = <0x01 0x03>;
						qcom,adc5-gen4;
					};

					pmih010x_vbat_sns_qbg {
						reg = <0x78f>;
						label = "pmih010x_vbat_sns_qbg";
						qcom,pre-scaling = <0x01 0x03>;
						qcom,adc5-gen4;
					};

					pmih010x_iin {
						reg = <0x717>;
						label = "pmih010x_iin";
						qcom,adc5-gen4;
					};

					pmih010x_ichg_fb {
						reg = <0x7a1>;
						label = "pmih010x_ichg_fb";
						qcom,adc5-gen4;
					};

					pmih010x_chg_temp {
						reg = <0x710>;
						label = "pmih010x_chg_temp";
						qcom,adc5-gen4;
					};

					pmih010x_lite_die_temp {
						reg = <0x718>;
						label = "pmih010x_lite_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc5-gen4;
					};

					pm8550_wlan_therm {
						reg = <0x146>;
						label = "pm8550_wlan_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pm8550_rec_therm {
						reg = <0x148>;
						label = "pm8550_rec_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
					};

					pm8550_xog_therm {
						reg = <0x14d>;
						label = "pm8550_xog_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen3;
					};

					pmih010x_spk_therm {
						reg = <0x74a>;
						label = "pmih010x_spk_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_chg_therm {
						reg = <0x74b>;
						label = "pmih010x_chg_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_batt_therm {
						reg = <0x744>;
						label = "pmih010x_batt_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_quiet_therm {
						reg = <0x74c>;
						label = "pmih010x_quiet_therm";
						qcom,ratiometric;
						qcom,pre-scaling = <0x01 0x01>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};

					pmih010x_mdisp_therm {
						reg = <0x75e>;
						label = "pmih010x_mdisp_therm";
						qcom,ratiometric;
						qcom,hw-settle-time = <0xc8>;
						qcom,adc-tm-type = <0x01>;
						qcom,adc5-gen4;
					};
				};
			};

			qcom,pm8550@1 {
				compatible = "qcom,spmi-pmic";
				reg = <0x01 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;

				pm8550_tz: pm8550-temp-alarm@a00 {
					compatible = "qcom,spmi-temp-alarm";
					reg = <0xa00>;
					interrupts = <0x01 0x0a 0x00 0x03>;
					#thermal-sensor-cells = <0x00>;
					io-channels = <&pmk8550_vadc>, <0x103>;
					io-channel-names = "thermal";
					phandle = <0x0d>;
				};

				pm8550_gpios: pinctrl@8800 {
					compatible = "qcom,pm8550-gpio";
					reg = <0x8800>;
					gpio-controller;
					#gpio-cells = <0x02>;
					interrupt-controller;
					#interrupt-cells = <0x02>;
					phandle = <0x09>;

					sys_therm_5_gpio3 {

						sys_therm_5_gpio3_default: sys_therm_5_gpio3_default {
							pins = "gpio3";
							bias-high-impedance;
							phandle = <0x02>;
						};
					};

					sys_therm_12_gpio2 {

						sys_therm_12_gpio2_default: sys_therm_12_gpio2_default {
							pins = "gpio2";
							bias-high-impedance;
							phandle = <0x03>;
						};
					};

					key_vol_up {

						key_vol_up_default: key_vol_up_default {
							pins = "gpio6";
							function = "normal";
							input-enable;
							bias-pull-up;
							power-source = <0x01>;
							phandle = <0x08>;
						};
					};
				};

				led-controller {
					compatible = "qcom,pm8350c-pwm";
					#address-cells = <0x01>;
					#size-cells = <0x00>;
					#pwm-cells = <0x02>;
					nvmem = <&pmk8550_sdam_21>, <&pmk8550_sdam_22>;
					nvmem-names = "lpg_chan_sdam", "lut_sdam";

					led@1 {
						reg = <0x01>;
						color = <0x01>;
						label = "red";
					};

					led@2 {
						reg = <0x02>;
						color = <0x02>;
						label = "green";
					};

					led@3 {
