	compatible = "qcom,alor-qrd", "qcom,alor", "qcom,qrd";
	qcom,msm-id = <0x2ad 0x10000>;
	qcom,board-id = <0x41 0xb1b0>;

	fragment@0 {
		target = <&spmi0_bus>;

		__overlay__ {

			pmk8550: qcom,pmk8550@0 {
				compatible = "qcom,spmi-pmic";
				reg = <0x00 0x00>;
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				phandle = <0x53>;

				pmk8550_sdam_1: sdam@7000 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7000>;
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x54>;

					smb1510_present: smb1510_present@5d {
						reg = <0x5d 0x01>;
						bits = <0x05 0x01>;
						phandle = <0x1a>;
					};

					ocp_log: ocp-log@76 {
						reg = <0x76 0x06>;
						phandle = <0x0c>;
					};
				};

				pmk8550_sdam_2: sdam@7100 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7100>;
					#address-cells = <0x01>;
					#size-cells = <0x01>;
					phandle = <0x55>;

					restart_reason: restart@48 {
						reg = <0x48 0x01>;
						bits = <0x01 0x07>;
						phandle = <0x18>;
					};

					wr_thermal_flag: wr_thermal-flag@58 {
						reg = <0x58 0x01>;
						phandle = <0x56>;
					};

					alarm_log: alarm-log@76 {
						reg = <0x76 0x06>;
						phandle = <0x57>;
					};

					fmd_set: fmd-set@9a {
						reg = <0x9a 0x01>;
						phandle = <0x58>;
					};

					fmd_chg_pon: fmd-chg-pon@9f {
						reg = <0x9f 0x01>;
						phandle = <0x59>;
					};

					fmd_cnt2_stop: fmd-cnt2-stop@a2 {
						reg = <0xa2 0x01>;
						phandle = <0x5a>;
					};

					bob1_off_mode_enable: bob1-off-mode-enable@50 {
						reg = <0x50 0x01>;
						phandle = <0x5b>;
					};

					xo_calib_data: xo_calib-data@59 {
						reg = <0x59 0x01>;
						phandle = <0x5c>;
					};

					extra_restart_reason: restart@49 {
						reg = <0x49 0x01>;
						bit = <0x00 0x07>;
						phandle = <0x3a>;
					};
				};

				pmk8550_sdam_5: sdam@7400 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7400>;
					phandle = <0x0a>;
				};

				pmk8550_sdam_6: sdam@7500 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7500>;
					phandle = <0x0b>;
				};

				pmk8550_sdam_13: ecm_sdam_0: sdam@7c00 {
					compatible = "qcom,spmi-sdam";
					reg = <0x7c00>;
					phandle = <0x1b>;
				};

				pmk8550_sdam_14: ecm_sdam_1: sdam@7d00 {
