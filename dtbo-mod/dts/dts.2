						qcom,pre-scaling = <0x01 0x01>;
					};

					pm8550_vref_1p25 {
						reg = <0x101>;
						label = "pm8550_vref_1p25";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pm8550_die_temp {
						reg = <0x103>;
						label = "pm8550_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pm8550_vph_pwr {
						reg = <0x18e>;
						label = "pm8550_vph_pwr";
						qcom,pre-scaling = <0x01 0x03>;
					};

					pm8550ve_d_die_temp {
						reg = <0x303>;
						label = "pm8550ve_d_die_temp";
						qcom,pre-scaling = <0x01 0x01>;
					};

					pm8550ve_f_die_temp {
						reg = <0x503>;
						label = "pm8550ve_f_die_temp";
